#include<iostream>
using namespace std;

struct stInfo
{
	int Age;
	bool HasDrivingLicense;
	bool HasRecommendtion;
};

stInfo ReadInfo()
{
	stInfo Info;

	cout << "Please enter Your Age?" << endl;
	cin >> Info.Age;
	cout << "Do You have a driver licene?" << endl;
	cin >> Info.HasDrivingLicense;
	cout << "Do You have a Recommendtion?" << endl;
	cin >> Info.HasRecommendtion;

	return Info;
}

bool IsAccepted(stInfo Info)
{
	if (Info.HasRecommendtion)
		return true;
	else
		return (Info.Age > 21 && Info.HasDrivingLicense);
}

void PrintResult(stInfo Info)
{
	if (IsAccepted(Info))
		cout << "\n Hired" << endl;
	else
		cout << "\n Rejected" << endl;
}

int main()
{
	PrintResult(ReadInfo());

	return 0;
}
